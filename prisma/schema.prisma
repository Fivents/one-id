generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ORG_OWNER
  EVENT_MANAGER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
  CANCELED
}

enum CheckInMethod {
  FACE_RECOGNITION
  QR_CODE
  MANUAL
}

enum TotemStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum PlanRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActorType {
  USER
  ORGANIZATION
  TOTEM
  SYSTEM
}

enum EntityType {
  USER
  ORGANIZATION
  EVENT
  TOTEM
  CHECK_IN
  SUBSCRIPTION
  PLAN
}

enum NotificationType {
  PLAN_REQUEST
  PLAN_APPROVED
  PLAN_REJECTED
  LIMIT_WARNING
  EXPIRATION_WARNING
  NEW_MEMBER
  EVENT_CREATED
  SYSTEM_MESSAGE
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
}

enum DocumentType {
  PASSPORT
  ID_CARD
  DRIVER_LICENSE
  OTHER
}

enum PrintOrientation {
  PORTRAIT
  LANDSCAPE
}

enum AuditAction {
  CHECK_IN
  CHECK_IN_APPROVED
  CHECK_IN_DENIED
  TOTEM_AUTH
  TOTEM_AUTH_SUCCESS
  TOTEM_AUTH_FAILED
  PARTICIPANT_CREATED
  PARTICIPANT_UPDATED
  PARTICIPANT_DELETED
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  USER_LOGIN
  USER_LOGOUT
  FACE_REGISTERED
  FACE_UPDATED
  FACE_DELETED
  EXPORT_DATA
  IMPORT_DATA
  PRINT_CONFIG_CREATED
  PRINT_CONFIG_UPDATED
  TOTEM_CREATED
  TOTEM_UPDATED
  TOTEM_DELETED
  PLAN_CREATED
  PLAN_UPDATED
  PLAN_DELETED
  PLAN_CHANGE_REQUESTED
  PLAN_CHANGE_APPROVED
  PLAN_CHANGE_REJECTED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_PASSWORD_RESET
  ORG_CREATED
  ORG_UPDATED
  ORG_DELETED
  ORG_ACTIVATED
  ORG_DEACTIVATED
  TOTEM_LINKED
  TOTEM_UNLINKED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_DELETED
}

// ── Models ─────────────────────────────────────────────────────────

model Organization {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  logoUrl String? @map("logo_url")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  subscription                   Subscription?
  memberships                    Membership[]
  events                         Event[]
  totemOrganizationSubscriptions TotemOrganizationSubscription[]
  people                         Person[]
  auditLogs                      AuditLog[]
  planChangeRequests             PlanChangeRequest[]

  @@map("organizations")
}

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  avatarUrl String? @map("avatar_url")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships          Membership[]
  sessions             Session[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  authIdentities       AuthIdentity[]
  resolvedPlanRequests PlanChangeRequest[] @relation("ResolvedByUser")

  @@map("users")
}

model Membership {
  id   String @id @default(uuid())
  role Role   @default(EVENT_MANAGER)

  userId         String @map("user_id")
  organizationId String @map("organization_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Session {
  id        String @id @default(uuid())
  deviceId  String @map("device_id")
  ipAddress String @map("ip_address")
  userAgent String @map("user_agent")
  tokenHash String @map("token_hash")

  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([userId])
  @@map("sessions")
}

model AuthIdentity {
  id String @id @default(uuid())

  provider     String
  providerId   String  @map("provider_id")
  passwordHash String? @map("password_hash")
  allowAccess  Boolean @default(true) @map("allow_access")

  userId String @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("auth_identities")
}

model Event {
  id          String  @id @default(uuid())
  name        String
  slug        String
  description String?
  timezone    String
  address     String?

  status EventStatus @default(DRAFT)

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  organizationId String  @map("organization_id")
  printConfigId  String? @map("print_config_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  printConfig             PrintConfig?             @relation(fields: [printConfigId], references: [id], onDelete: SetNull)
  participants            EventParticipant[]
  totemEventSubscriptions TotemEventSubscription[]
  auditLogs               AuditLog[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@index([printConfigId])
  @@map("events")
}

model Totem {
  id String @id @default(uuid())

  name        String
  accessCode  String      @unique @map("access_code")
  accessToken String?     @unique @map("access_token")
  status      TotemStatus @default(ACTIVE)

  price    Float
  discount Float

  lastHeartbeat DateTime? @map("last_heartbeat")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  organizationSubscriptions TotemOrganizationSubscription[]
  sessions                  TotemSession[]

  @@map("totems")
}

model TotemSession {
  id        String @id @default(uuid())
  tokenHash String @map("token_hash")
  ipAddress String @map("ip_address")
  userAgent String @map("user_agent")

  totemId String @map("totem_id")

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  totem Totem @relation(fields: [totemId], references: [id], onDelete: Cascade)

  @@index([totemId])
  @@map("totem_sessions")
}

model TotemOrganizationSubscription {
  id String @id @default(uuid())

  totemId        String @map("totem_id")
  organizationId String @map("organization_id")

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  totem              Totem                    @relation(fields: [totemId], references: [id], onDelete: Cascade)
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventSubscriptions TotemEventSubscription[]

  @@index([totemId])
  @@index([organizationId])
  @@map("totem_organization_subscriptions")
}

model TotemEventSubscription {
  id           String @id @default(uuid())
  locationName String @map("location_name")

  totemOrganizationSubscriptionId String @map("totem_organization_subscription_id")
  eventId                         String @map("event_id")

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  totemOrganizationSubscription TotemOrganizationSubscription @relation(fields: [totemOrganizationSubscriptionId], references: [id], onDelete: Cascade)
  event                         Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkIns                      CheckIn[]

  @@index([totemOrganizationSubscriptionId])
  @@index([eventId])
  @@map("totem_event_subscriptions")
}

model Person {
  id           String        @id @default(uuid())
  name         String
  email        String
  document     String?
  documentType DocumentType? @map("document_type")
  phone        String?

  organizationId String @map("organization_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  faces             PersonFace[]
  eventParticipants EventParticipant[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@map("people")
}

model PersonFace {
  id String @id @default(uuid())

  embedding Bytes
  imageHash String @map("image_hash")
  imageUrl  String @map("image_url")

  personId String @map("person_id")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("person_faces")
}

model EventParticipant {
  id       String  @id @default(uuid())
  company  String?
  jobTitle String? @map("job_title")

  personId String @map("person_id")
  eventId  String @map("event_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  person   Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkIns CheckIn[]

  @@unique([personId, eventId])
  @@index([personId])
  @@index([eventId])
  @@map("event_participants")
}

model CheckIn {
  id          String        @id @default(uuid())
  method      CheckInMethod
  confidence  Float?
  checkedInAt DateTime      @map("checked_in_at")

  eventParticipantId       String @map("event_participant_id")
  totemEventSubscriptionId String @map("totem_event_subscription_id")

  eventParticipant       EventParticipant       @relation(fields: [eventParticipantId], references: [id], onDelete: Cascade)
  totemEventSubscription TotemEventSubscription @relation(fields: [totemEventSubscriptionId], references: [id], onDelete: Cascade)

  @@index([eventParticipantId])
  @@index([totemEventSubscriptionId])
  @@map("check_ins")
}

model AuditLog {
  id String @id @default(uuid())

  action      AuditAction
  description String?
  metadata    Json?

  sessionId      String? @map("session_id")
  organizationId String? @map("organization_id")
  userId         String? @map("user_id")
  eventId        String? @map("event_id")

  createdAt DateTime @default(now()) @map("created_at")

  session      Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([organizationId])
  @@index([userId])
  @@index([eventId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model PrintConfig {
  id String @id @default(cuid())

  // Paper settings
  paperWidth  Float            @default(62) @map("paper_width") // mm
  paperHeight Float            @default(100) @map("paper_height") // mm
  orientation PrintOrientation @default(PORTRAIT) // portrait | landscape

  // Margins
  marginTop    Float @default(5) @map("margin_top")
  marginRight  Float @default(5) @map("margin_right")
  marginBottom Float @default(5) @map("margin_bottom")
  marginLeft   Float @default(5) @map("margin_left")

  // Fivents logo (always required)
  showFiventsLogo     Boolean @default(true) @map("show_fivents_logo")
  fiventsLogoPosition String  @default("top") @map("fivents_logo_position") // top|bottom
  fiventsLogoSize     Float   @default(20) @map("fivents_logo_size") // mm height

  // Organization logo
  showOrgLogo     Boolean @default(true) @map("show_org_logo")
  orgLogoPosition String  @default("top") @map("org_logo_position")
  orgLogoSize     Float   @default(25) @map("org_logo_size")

  // QR Code
  showQrCode     Boolean @default(true) @map("show_qr_code")
  qrCodePosition String  @default("center") @map("qr_code_position")
  qrCodeSize     Float   @default(30) @map("qr_code_size") // mm
  qrCodeContent  String  @default("participant_id") @map("qr_code_content") // participant_id|check_in_url|custom

  // Participant name
  showName     Boolean @default(true) @map("show_name")
  namePosition String  @default("center") @map("name_position")
  nameFontSize Float   @default(16) @map("name_font_size") // pt
  nameBold     Boolean @default(true) @map("name_bold")

  // Company
  showCompany     Boolean @default(true) @map("show_company")
  companyPosition String  @default("center") @map("company_position")
  companyFontSize Float   @default(12) @map("company_font_size")

  // Job title
  showJobTitle     Boolean @default(true) @map("show_job_title")
  jobTitlePosition String  @default("center") @map("job_title_position")
  jobTitleFontSize Float   @default(10) @map("job_title_font_size")

  // Items ordering (JSON array of item keys in display order)
  itemsOrder String @default("[\"fiventsLogo\",\"orgLogo\",\"name\",\"company\",\"jobTitle\",\"qrCode\"]") @map("items_order")

  // Printer settings
  printerDpi  Int    @default(203) @map("printer_dpi")
  printerType String @default("thermal") @map("printer_type") // thermal|inkjet|laser
  printSpeed  Int    @default(3) @map("print_speed") // 1-5
  copies      Int    @default(1)

  // Styling
  backgroundColor String @default("#ffffff") @map("background_color")
  textColor       String @default("#000000") @map("text_color")
  fontFamily      String @default("Arial") @map("font_family")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events Event[]

  @@map("print_configs")
}

model Plan {
  id          String @id @default(uuid())
  name        String
  description String
  price       Float
  discount    Float

  isCustom  Boolean @default(false) @map("is_custom")
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  subscriptions               Subscription[]
  currentPlanChangeRequests   PlanChangeRequest[] @relation("CurrentPlan")
  requestedPlanChangeRequests PlanChangeRequest[] @relation("RequestedPlan")
  planFeatures                PlanFeature[]

  @@map("plans")
}

model Feature {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  type        String // e.g. "boolean", "number", "string"
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  planFeatures PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id    String @id @default(uuid())
  value String

  featureId String @map("feature_id")
  planId    String @map("plan_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([featureId, planId])
  @@index([featureId])
  @@index([planId])
  @@map("plan_features")
}

model Subscription {
  id String @id @default(uuid())

  organizationId String @unique @map("organization_id")
  planId         String @map("plan_id")

  startedAt DateTime @map("started_at")
  expiresAt DateTime @map("expires_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscriptions")
}

model PlanChangeRequest {
  id      String            @id @default(uuid())
  message String
  status  PlanRequestStatus @default(PENDING)

  organizationId  String @map("organization_id")
  currentPlanId   String @map("current_plan_id")
  requestedPlanId String @map("requested_plan_id")

  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id")
  resolvedNote String?   @map("resolved_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentPlan   Plan         @relation("CurrentPlan", fields: [currentPlanId], references: [id])
  requestedPlan Plan         @relation("RequestedPlan", fields: [requestedPlanId], references: [id])
  resolvedBy    User?        @relation("ResolvedByUser", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([currentPlanId])
  @@index([requestedPlanId])
  @@index([resolvedById])
  @@map("plan_change_requests")
}

model Notification {
  id String @id @default(uuid())

  channel NotificationChannel
  type    NotificationType
  title   String
  message String
  data    Json?

  userId String @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
