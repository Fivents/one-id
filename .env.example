# ===========================================
# Fivents - Credenciamento Facial para Eventos
# Coloque suas variáveis de ambiente aqui. Não compartilhe este arquivo publicamente.
# Renomeie para .env e configure os valores antes de rodar a aplicação. 
# ===========================================

# PostgreSQL (Neon) Connection String
# Formato: postgresql://user:password@host/database?sslmode=require
# Obtenha em: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-example-123456.sa-east-1.aws.neon.tech/fivents?sslmode=require"

# URL base da aplicação (usado para QR codes e links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"

# JWT Secret (gere com: openssl rand -base64 32)
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_BASE64_32"

# JWT Token expiration
JWT_EXPIRES_IN="7d"

# Google OAuth (apenas @fivents.com)
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="CONFIGURE_AQUI"
GOOGLE_CLIENT_SECRET="CONFIGURE_AQUI"
